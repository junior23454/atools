<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>UKRAINE GTA - Онлайн гра про Україну!</title>
    <style>@font-face {
  font-family: 'Gotham Pro';
  src: url('data:font/ttf;base64,') format('truetype');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Gotham Pro';
  src: url('data:font/ttf;base64,') format('truetype');
  font-weight: 300;
  font-style: normal;
  font-display: swap;
}

html {
  box-sizing: border-box;
}

body::-webkit-scrollbar {
  width: 0;
}

body::-webkit-scrollbar-track {
  background-color: transparent;
}

body::-webkit-scrollbar-thumb {
  background-color: transparent;
}

body {
  background: #0f0f16;
  font-family: 'Gotham Pro';
  margin: 0;
  min-height: 100vh;
}
.wrapper {
  width: 100%;
  min-height: 100vh;

  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
}

.wrapper::before,
.wrapper::after {
  content: '';
  width: 40vh;
  height: 40vh;
  position: fixed;
  filter: blur(200px);
  border-radius: 50%;
  bottom: -32vh;
}

.wrapper::before {
  left: 35vh;
  background: linear-gradient(
    180deg,
    rgba(240, 104, 48, 0.8) 0%,
    rgba(240, 104, 48, 0) 100%
  );

  animation: bottom-right 6s 1s linear infinite;
}

.wrapper::after {
  right: 30vh;
  background: linear-gradient(
    180deg,
    rgba(33, 122, 157, 1) 0%,
    rgba(33, 122, 157, 0) 100%
  );
  animation: bottom-right 5s linear infinite;
}

.background {
  position: fixed;
  top: 0px;
  left: 0px;
  width: 100%;
  height: 100%;
  object-fit: cover;
  pointer-events: none;
}

.content {
  margin: 0 auto 0 auto;
  padding-top: 28vh;
  max-width: 920px;
  width: calc(100% - 30px);

  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  height: 140px;
  width: auto;
  margin-bottom: 20px;
}

h1 {
  color: #fffbef;
  text-align: center;
  font-weight: 700;
  line-height: 130%;
  width: 600px;
  font-size: 28px;
  margin: 0;
}

.description {
  color: #fffbef;
  font-weight: 500;
  line-height: 140%;
  width: 100%;
  text-align: center;
  font-size: 14px;
}

.sub-title {
  color: rgba(255, 251, 239, 0.6);
  text-align: center;
  font-size: 14px;
  font-weight: 300;
  max-width: 100%;
  margin-top: 25px;
}

.footer {
  margin: 30px 0 38px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.addition-data {
  color: rgba(255, 251, 239, 0.3);
  font-size: 12px;
  text-align: center;
  white-space: nowrap;
  line-height: 140%;
  margin-bottom: 20px;
}

.addition-data div:last-child {
  padding-top: 5px;
}

.label {
  border: 1px solid rgba(255, 255, 255, 0.05);
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(52px);
  padding: 0 24px;

  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 8px;
  height: 52px;
  border-radius: 100px;
}

.label img {
  width: 24px;
  height: 24px;
  object-fit: contain;
}

.label span {
  color: #fffbef;
  font-size: 16px;
  font-weight: 400;
  white-space: nowrap;
}

@media (max-width: 1500px) {
  .wrapper::before {
    left: 10vw;
  }

  .wrapper::after {
    right: 10vw;
  }
}

@media (max-width: 1199.98px) {
  .wrapper::before,
  .wrapper::after {
    width: 230px;
    height: 230px;
    filter: blur(100px);
  }

  .wrapper::before {
    left: 5vw;
    bottom: -150px;

    animation: bottom-right-mobile 6s 0.5s linear infinite;
  }

  .wrapper::after {
    right: 0vw;
    top: -100px;
    animation: bottom-right-mobile 5s linear infinite;
  }
}

@media (max-width: 767.98px), (max-height: 686px) {
  .content {
    padding-top: 15vh;
  }

  .logo {
    height: 110px;
  }

  h1 {
    font-size: 22px;
    width: 100%;
  }

  .sub-title {
    font-size: 12px;
  }

  .footer {
    bottom: 36px;
  }

  .addition-data {
    font-size: 12px;
  }

  .label {
    padding: 0 18px;

    gap: 4px;
    height: 42px;
    border-radius: 100px;
  }

  .label img {
    width: 18px;
    height: 18px;
  }

  .label span {
    font-size: 14px;
    font-weight: 400;
  }
}

@media (max-height: 686px) {
  .logo {
    height: 90px;
  }

  h1 {
    margin: 5px 0 0 0;
  }

  .footer {
    margin: 20px 0 20px 0;
  }

  .sub-title {
    margin-top: 20px;
  }
}

@media (max-height: 460px) {
  .content {
    padding-top: 40px;
  }

  .label {
    margin-top: 10px;
    padding: 0 14px;
    height: 36px;
  }

  .sub-title {
    top: calc(100% + 20px);
  }
}

@keyframes bottom-left {
  0% {
    width: 40vh;
    height: 40vh;
    transform: translate(0, 0);
  }
  30% {
    width: 35vh;
    height: 35vh;
    transform: translate(-3vw, -3vh);
  }
  60% {
    width: 42vh;
    height: 42vh;
    transform: translate(-3vw, 0);
  }
  100% {
    width: 40vh;
    height: 40vh;
    transform: translate(0, 0);
  }
}

@keyframes bottom-right {
  0% {
    width: 40vh;
    height: 40vh;
    transform: translate(0, 0);
  }
  30% {
    width: 38vh;
    width: 38vh;
    transform: translate(0, -5vh);
  }
  60% {
    width: 43vh;
    width: 43vh;
    transform: translate(-4vw, -5vh);
  }
  100% {
    width: 40vh;
    height: 40vh;
    transform: translate(0, 0);
  }
}

@keyframes bottom-left-mobile {
  0% {
    width: 230px;
    height: 230px;
    transform: translate(0, 0);
  }
  30% {
    width: 220px;
    height: 220px;
    transform: translate(-15vw, 0);
  }
  60% {
    width: 210px;
    height: 210px;
    transform: translate(-15vw, 55px);
  }
  100% {
    width: 230px;
    height: 230px;
    transform: translate(0, 0);
  }
}

@keyframes bottom-right-mobile {
  0% {
    width: 230px;
    height: 230px;
    transform: translate(0, 0);
  }
  30% {
    width: 205px;
    height: 205px;
    transform: translate(-12vw, 0);
  }
  60% {
    width: 230px;
    height: 230px;
    transform: translate(-13vw, -40px);
  }
  100% {
    width: 230px;
    height: 230px;
    transform: translate(0, 0);
  }
}
</style>
